+// SecretStruct represents the DBus secret structure: (oayays)
+// o: ObjectPath (session)
+// ay: []byte (parameters)
+// ay: []byte (value)
+// s: string (content_type)
+type SecretStruct struct {
+	Session     dbus.ObjectPath
+	Parameters  []byte
+	Value       []byte
+	ContentType string
+}
+
+// D-Bus Secret Service constants
+const (
+	secretServiceBusName    = "org.freedesktop.secrets"
+	secretServiceObjectPath = "/org/freedesktop/secrets"
+	secretServiceInterface  = "org.freedesktop.Secret.Service"
+	collectionInterface     = "org.freedesktop.Secret.Collection"
+	itemInterface           = "org.freedesktop.Secret.Item"
+)
+
 var (
-	ErrNotFound = errors.New("Could not found value in keystore")
+	ErrNotFound           = errors.New("Could not found value in keystore")
+	ErrServiceUnavailable = errors.New("Secret Service is not available")
+	ErrCollectionNotFound = errors.New("Collection not found")
 )
 
+// connectToSecretService connects to D-Bus and returns the Secret Service object
+func connectToSecretService() (*dbus.Conn, dbus.BusObject, error) {
+	conn, err := dbus.SessionBus()
+	if err != nil {
+		return nil, nil, fmt.Errorf("failed to connect to session bus: %w", err)
+	}
+
+	// Check if Secret Service is available by trying to access it
+	serviceObj := conn.Object(secretServiceBusName, secretServiceObjectPath)
+	var result dbus.Variant
+	err = serviceObj.Call("org.freedesktop.DBus.Properties.Get", 0,
+		secretServiceInterface, "Collections").Store(&result)
+	if err != nil {
+		conn.Close()
+		return nil, nil, ErrServiceUnavailable
+	}
+
+	return conn, serviceObj, nil
+}
+
+// openSession opens a session with the Secret Service for encryption
+func openSession(serviceObj dbus.BusObject) (dbus.ObjectPath, error) {
+	var sessionPath dbus.ObjectPath
+	var output dbus.Variant
+
+	err := serviceObj.Call(secretServiceInterface+".OpenSession", 0, "plain", dbus.MakeVariant("")).Store(&output, &sessionPath)
+	if err != nil {
+		return "", fmt.Errorf("failed to open session: %w", err)
+	}
+
+	return sessionPath, nil
+}
+
+// getCollection searches for an existing collection by alias or label
+func getCollection(conn *dbus.Conn, serviceObj dbus.BusObject, collectionName string) (dbus.ObjectPath, error) {
+	// Try to read "default" alias first
+	var collectionPath dbus.ObjectPath
+	err := serviceObj.Call(secretServiceInterface+".ReadAlias", 0, "default").Store(&collectionPath)
+	if err == nil && collectionPath != "/" && collectionPath != "" {
+		// Check if this default collection has our label
+		collObj := conn.Object(secretServiceBusName, collectionPath)
+		var labelVariant dbus.Variant
+		err := collObj.Call("org.freedesktop.DBus.Properties.Get", 0,
+			collectionInterface, "Label").Store(&labelVariant)
+		if err == nil {
+			if label, ok := labelVariant.Value().(string); ok && label == collectionName {
+				return collectionPath, nil
+			}
+		}
+	}
+
+	// Get all collections and check labels
+	var collectionsVariant dbus.Variant
+	err = serviceObj.Call("org.freedesktop.DBus.Properties.Get", 0,
+		secretServiceInterface, "Collections").Store(&collectionsVariant)
+	if err != nil {
+		return "", fmt.Errorf("failed to get collections: %w", err)
+	}
+
+	collections, ok := collectionsVariant.Value().([]dbus.ObjectPath)
+	if !ok {
+		return "", fmt.Errorf("failed to parse collections")
+	}
+
+	// Check each collection's label
+	for _, collPath := range collections {
+		collObj := conn.Object(secretServiceBusName, collPath)
+		var labelVariant dbus.Variant
+		err := collObj.Call("org.freedesktop.DBus.Properties.Get", 0,
+			collectionInterface, "Label").Store(&labelVariant)
+		if err == nil {
+			if label, ok := labelVariant.Value().(string); ok && label == collectionName {
+				return collPath, nil
+			}
+		}
+	}
+
+	return "", ErrCollectionNotFound
+}
+
+// createCollection creates a new collection with the given name
+func createCollection(conn *dbus.Conn, serviceObj dbus.BusObject, collectionName string) (dbus.ObjectPath, error) {
+	properties := map[string]dbus.Variant{
+		"org.freedesktop.Secret.Collection.Label": dbus.MakeVariant(collectionName),
+	}
+
+	var collectionPath dbus.ObjectPath
+	var prompt dbus.ObjectPath
+
+	// Use empty string for alias - most implementations only support "default" or empty
+	err := serviceObj.Call(secretServiceInterface+".CreateCollection", 0, properties, "").Store(&collectionPath, &prompt)
+	if err != nil {
+		return "", fmt.Errorf("failed to create collection: %w", err)
+	}
+
+	// If prompt is returned, we need to handle it (user interaction required)
+	if prompt != "/" && prompt != "" {
+		// Try to complete the prompt
+		promptObj := conn.Object(secretServiceBusName, prompt)
+
+		// Prompt the user
+		err = promptObj.Call("org.freedesktop.Secret.Prompt.Prompt", 0, "").Err
+		if err != nil {
+			return "", fmt.Errorf("failed to prompt user: %w", err)
+		}
+
+		// For simplicity, we'll return an error asking for user interaction
+		// A full implementation would wait for the Completed signal
+		return "", fmt.Errorf("collection creation requires user interaction - please check your keyring application")
+	}
+
+	return collectionPath, nil
+}
+
+// unlockCollection unlocks a collection if it's locked
+func unlockCollection(serviceObj dbus.BusObject, collectionPath dbus.ObjectPath) error {
+	var unlocked []dbus.ObjectPath
+	var prompt dbus.ObjectPath
+
+	err := serviceObj.Call(secretServiceInterface+".Unlock", 0, []dbus.ObjectPath{collectionPath}).Store(&unlocked, &prompt)
+	if err != nil {
+		return fmt.Errorf("failed to unlock collection: %w", err)
+	}
+
+	if prompt != "/" && prompt != "" {
+		return fmt.Errorf("collection unlock requires user interaction")
+	}
+
+	return nil
+}
+
+// searchItem searches for an item in a collection by its label or attributes
+func searchItem(conn *dbus.Conn, collectionPath dbus.ObjectPath, itemId string) (dbus.ObjectPath, error) {
+	collObj := conn.Object(secretServiceBusName, collectionPath)
+
+	// Search by attributes
+	attributes := map[string]string{
+		"id": itemId,
+	}
+
+	var items []dbus.ObjectPath
+	err := collObj.Call(collectionInterface+".SearchItems", 0, attributes).Store(&items)
+	if err == nil && len(items) > 0 {
+		return items[0], nil
+	}
+
+	// Try searching by label as fallback
+	var itemsVariant dbus.Variant
+	err = collObj.Call("org.freedesktop.DBus.Properties.Get", 0,
+		collectionInterface, "Items").Store(&itemsVariant)
+	if err != nil {
+		return "", fmt.Errorf("failed to get collection items: %w", err)
+	}
+
+	allItems, ok := itemsVariant.Value().([]dbus.ObjectPath)
+	if !ok {
+		return "", fmt.Errorf("failed to parse collection items")
+	}
+
+	// Check each item's label
+	for _, itemPath := range allItems {
+		itemObj := conn.Object(secretServiceBusName, itemPath)
+		var labelVariant dbus.Variant
+		err = itemObj.Call("org.freedesktop.DBus.Properties.Get", 0,
+			itemInterface, "Label").Store(&labelVariant)
+		if err == nil {
+			if label, ok := labelVariant.Value().(string); ok && label == itemId {
+				return itemPath, nil
+			}
+		}
+	}
+
+	return "", ErrNotFound
+}
+
+// getOrCreateDefaultCollection gets the default collection or creates one with our label
+func getOrCreateDefaultCollection(conn *dbus.Conn, serviceObj dbus.BusObject, collectionName string) (dbus.ObjectPath, error) {
+	// First try to find our collection by label
+	collectionPath, err := getCollection(conn, serviceObj, collectionName)
+	if err == nil {
+		_ = unlockCollection(serviceObj, collectionPath)
+		return collectionPath, nil
+	}
+
+	// Try to use the default collection
+	var defaultPath dbus.ObjectPath
+	err = serviceObj.Call(secretServiceInterface+".ReadAlias", 0, "default").Store(&defaultPath)
+	if err == nil && defaultPath != "/" && defaultPath != "" {
+		_ = unlockCollection(serviceObj, defaultPath)
+		return defaultPath, nil
+	}
+
+	// No default collection exists, create one
+	collectionPath, err = createCollection(conn, serviceObj, collectionName)
+	if err != nil {
+		return "", fmt.Errorf("failed to create collection: %w", err)
+	}
+
+	return collectionPath, nil
+}
+
+// ensureCollectionExistsInternal ensures the collection exists using provided connection
+func ensureCollectionExistsInternal(conn *dbus.Conn, serviceObj dbus.BusObject, collectionName string) (dbus.ObjectPath, error) {
+	return getOrCreateDefaultCollection(conn, serviceObj, collectionName)
+}
+
+// VerifySecretServiceAvailable checks if the D-Bus Secret Service is available
+func VerifySecretServiceAvailable() error {
+	conn, _, err := connectToSecretService()
+	if err != nil {
+		return err
+	}
+	defer conn.Close()
+	return nil
+}
+
+// EnsureCollectionExists ensures the collection exists, creating it if necessary
+func EnsureCollectionExists(collectionName string) (dbus.ObjectPath, error) {
+	conn, serviceObj, err := connectToSecretService()
+	if err != nil {
+		return "", fmt.Errorf("failed to connect to Secret Service: %w", err)
+	}
+	defer conn.Close()
+
+	return ensureCollectionExistsInternal(conn, serviceObj, collectionName)
+}
+
